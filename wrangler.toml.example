name = "melon-api"
main = "src/index.ts"
compatibility_date = "2026-06-22"
workers_dev = true

[vars]
BANGUMI_API_BASE = "https://api.bgm.tv"
BANGUMI_WEB_BASE = "https://bangumi.tv"
BANGUMI_DATA_SOURCE = "https://cdn.jsdelivr.net/npm/bangumi-data@0.3/dist/data.json"
BANGUMI_USER_AGENT = "melon-api"

[[r2_buckets]]
binding = "CACHE_BUCKET"
bucket_name = "melon-api-cache"

# Optional. Create with:
# wrangler d1 create melon-api-index
# Then fill database_id.
#
# [[d1_databases]]
# binding = "DB"
# database_name = "melon-api-index"
# database_id = ""

# Logging:
#
# [observability]
# enabled = true
# head_sampling_rate = 1

[triggers]
crons = ["0 0 * * *"]
